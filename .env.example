# ================================================================
# SERVER CONFIGURATION
# ================================================================
PORT=5000
NODE_ENV=production

# ================================================================
# DATABASE
# ================================================================
# Use your MongoDB Atlas connection string in production
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ================================================================
# AUTHENTICATION
# ================================================================
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# ================================================================
# RAZORPAY PAYMENT GATEWAY
# ================================================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ================================================================
# CORS / NETWORKING
# Comma-separated list of allowed frontend origins.
# Add your deployed frontend URL here so CORS allows it.
# ================================================================
CORS_ORIGIN=https://your-frontend.vercel.app

# ================================================================
# EMAIL (SMTP)
# ================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
# Use a Gmail App Password (not your real password)
SMTP_PASS=your_gmail_app_password
MAIL_FROM=your_gmail@gmail.com

# ================================================================
# OPENAI (Chatbot feature — optional)
# ================================================================
OPENAI_API_KEY=sk-your_openai_api_key

# ================================================================
# FRONTEND (used by Vite build — set in your frontend hosting env)
# ================================================================
# VITE_API_BASE_URL=https://your-backend.onrender.com
# VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
